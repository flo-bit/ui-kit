{
  "name": "@foxui/core",
  "private": false,
  "version": "0.8.3",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "build:package": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "prepack": "svelte-kit sync && svelte-package && node ./scripts/cleanup.js",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint ."
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts"
    },
    "./icons": {
      "types": "./src/lib/icons/index.ts",
      "svelte": "./src/lib/icons/index.ts"
    },
    "./moving-icons": {
      "types": "./src/lib/moving-icons/index.ts",
      "svelte": "./src/lib/moving-icons/index.ts"
    },
    "./theme.css": "./src/lib/theme.css"
  },
  "types": "./src/lib/index.ts",
  "svelte": "./src/lib/index.ts",
  "publishOverrides": {
    "files": [
      "dist"
    ],
    "svelte": "./dist/index.js",
    "exports": {
      ".": {
        "types": "./dist/types.d.ts",
        "svelte": "./dist/index.js"
      },
      "./icons": {
        "types": "./dist/icons/index.d.ts",
        "svelte": "./dist/icons/index.js"
      },
      "./moving-icons": {
        "types": "./dist/moving-icons/index.d.ts",
        "svelte": "./dist/moving-icons/index.js"
      },
      "./theme.css": "./dist/theme.css"
    },
    "types": "./dist/types.d.ts"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.2",
    "svelte-check": "^4.4.3",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@jis3r/icons": "^2.7.0",
    "@lucide/svelte": "^1.8.0",
    "@number-flow/svelte": "^0.4.0",
    "bits-ui": "^2.16.2",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "mode-watcher": "^1.1.0",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "web-haptics": "^0.0.6"
  },
  "peerDependencies": {
    "svelte": ">=5",
    "tailwindcss": ">=3"
  },
  "keywords": [
    "svelte",
    "ui-kit",
    "3d",
    "components"
  ],
  "description": "ui kit - svelte 5 + tailwind 4 - base components",
  "homepage": "https://flo-bit.dev/ui-kit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flo-bit/ui-kit.git"
  },
  "author": "flo-bit (http://flo-bit.dev/)",
  "bugs": "https://github.com/flo-bit/ui-kit/issues",
  "license": "MIT"
}
